PORT=5000

# MongoDB (dev Compose uses admin/admin123 and host `db`)
MONGO_URI=mongodb://admin:admin123@db:27017/ai-cold-email-dev?authSource=admin

CORS_ORIGIN=http://localhost:5173

JWT_ACCESS_TOKEN_SECRET=alpha
JWT_REFRESH_TOKEN_SECRET=beta

EMAIL_SERVICE=gmail
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=you@example.com
EMAIL_PASS=<SMTP_PASSWORD>

# Redis: leave blank to use the local Compose redis service, or set to your
# external provider (example: Upstash). Do NOT commit real credentials.
# Example: REDIS_URL="rediss://default:<UPSTASH_TOKEN>@loved-crow-66711.upstash.io:6379"
REDIS_URL=
