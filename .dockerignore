# Ignore local node modules and lock/debug files
node_modules
**/node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment / secrets
.env
.env.*.local

# Logs and OS metadata
logs
*.log
.DS_Store
.vscode/
.idea/

# Docker / compose files (not required in image context)
docker-compose*.yml
docker-compose*.yaml

# Build output
dist/
build/
coverage/
